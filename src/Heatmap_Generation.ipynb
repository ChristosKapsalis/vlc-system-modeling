   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from mpl_toolkits.mplot3d import Axes3D\n",
    "\n",
    "data = {\n",
    "    \"X\": [0.05,0.15,0.25,0.05,0.15,0.25,0.05,0.15,0.25],\n",
    "    \"Y\": [0.25,0.25,0.25,0.15,0.15,0.15,0.05,0.05,0.05],\n",
    "    \"Value1\": [64.517,54.267,36.017,139.017,99.517,56.267,234.517,150.267,77.017],\n",
    "    \"Value2\": [54.517,143.017,263.267,42.517,94.267,152.017,23.017,46.767,66.017],\n",
    "    \"Value3\": [242.767,161.017,78.767,154.017,106.517,59.267,74.267,56.017,28.017]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(data)\n",
    "\n",
    "x = sorted(df[\"X\"].unique())\n",
    "y = sorted(df[\"Y\"].unique())\n",
    "X, Y = np.meshgrid(x, y)\n",
    "\n",
    "Z1 = df.pivot(index=\"Y\", columns=\"X\", values=\"Value1\").values\n",
    "Z2 = df.pivot(index=\"Y\", columns=\"X\", values=\"Value2\").values\n",
    "Z3 = df.pivot(index=\"Y\", columns=\"X\", values=\"Value3\").values\n",
    "\n",
    "fig, axs = plt.subplots(1,3, figsize=(18,5))\n",
    "\n",
    "for ax, Z, title in zip(axs, [Z1, Z2, Z3],\n",
    "                        [\"LED1 Intensity\", \"LED2 Intensity\", \"LED3 Intensity\"]):\n",
    "    c = ax.contourf(X, Y, Z, cmap=\"inferno\", levels=20)\n",
    "    fig.colorbar(c, ax=ax)\n",
    "    ax.set_title(title)\n",
    "    ax.set_xlabel(\"X [m]\")\n",
    "    ax.set_ylabel(\"Y [m]\")\n",
    "\n",
    "plt.savefig("heatmap_led1.png", dpi=300, bbox_inches="tight")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
